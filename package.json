{
  "name": "icpswap-extractor",
  "version": "1.0.0",
  "private": true,
  "description": "Extracts ICPSwap swap transactions from Internet Computer storage canisters and lands them as CSV in Amazon S3, running on AWS Fargate",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RurociagDanych/icpswap-extractor"
  },
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.799.0",
    "@aws-sdk/lib-storage": "^3.799.0",
    "@dfinity/agent": "^0.20.2",
    "@dfinity/candid": "^0.20.2",
    "@dfinity/principal": "^0.20.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
