aws_region  = "us-east-1"
name_prefix = "icpswap-extractor"

# Required. Read this from terraform/aws-storage outputs.
bucket_name = "my-existing-raw-data-bucket"

# For tests and low-friction evaluation only: default to the account default VPC
# so you do not need to provision dedicated networking just to try the stack.
use_default_vpc = true

# Required only when use_default_vpc = false.
vpc_id     = null
subnet_ids = []

# Optional. Leave empty to use the managed ECR repository with the :latest tag.
container_image = ""

# Scheduled runs use 'sync' (backfill-if-needed, then REST incremental against the
# ICPSwap /transaction/find API). Run the one-time canister archive manually with
# scripts/aws_build_push_and_run.sh --mode canister before relying on sync.
container_command = [
  "node",
  "dist/index.js",
  "--mode",
  "sync",
]

s3_prefix           = "icpswap"
assign_public_ip    = true
schedule_expression = "rate(24 hour)"

# Optional. Subscribe an email to failed-task alerts (confirm the subscription email after apply).
alert_email = ""

tags = {
  Owner       = "data-platform"
  CostCenter  = "analytics"
  Environment = "prod"
}
